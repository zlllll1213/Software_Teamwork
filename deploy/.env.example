# Local/demo integration baseline. Values are placeholders, not production secrets.

COMPOSE_PROJECT_NAME=software-teamwork-local

POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

GATEWAY_HTTP_PORT=8080
AUTH_HTTP_PORT=8001
FILE_HTTP_PORT=8082
KNOWLEDGE_HTTP_PORT=8083
QA_HTTP_PORT=8084
DOCUMENT_HTTP_PORT=8085
AI_GATEWAY_HTTP_PORT=8086
PARSER_HTTP_PORT=8087

POSTGRES_PASSWORD=local-demo-postgres-password
MINIO_ROOT_USER=minio_local_demo
MINIO_ROOT_PASSWORD=minio-local-demo-password

INTERNAL_SERVICE_TOKEN=local-dev-internal-service-token-change-me
TOKEN_HASH_SECRET=local-demo-token-hash-secret-change-me
AI_GATEWAY_SERVICE_TOKEN_HASHES=sha256:26c6719c056dabe8530ea09f1e8f7593cbcf98a060731c0fc786a5eb48e71ce7
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY=local-demo-credential-key-change-me
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY_REF=local-demo-key-v1

LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=LocalDemoAdmin#12345

GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODEL_ID=local-placeholder-chat
PARSER_BACKEND=ppstructurev3
PARSER_LOAD_BACKEND_ON_STARTUP=false

# Optional Docker build acceleration. Defaults favor verified builds; uncomment
# and adjust these in deploy/.env when local network mirrors are needed.
# DOCKER_IMAGE_REGISTRY_PREFIX=
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine
# QDRANT_IMAGE=qdrant/qdrant:v1.18.2
# MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
# MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
# GO_DOCKER_GOPROXY=https://proxy.golang.org,direct
# GO_DOCKER_GOSUMDB=sum.golang.org
# ALPINE_MIRROR=
# DEBIAN_APT_MIRROR=
# DEBIAN_SECURITY_APT_MIRROR=
# PIP_INDEX_URL=
# UV_DEFAULT_INDEX=
# UV_INDEX=

# Knowledge retrieval defaults. Leave optional URLs empty for the fast local
# baseline; set them when running real Qdrant or AI Gateway integration smoke.
EMBEDDING_PROVIDER=local_hashing
EMBEDDING_MODEL=local_hashing
EMBEDDING_DIMENSION=384
QDRANT_COLLECTION=knowledge_chunks
KNOWLEDGE_QDRANT_URL=
KNOWLEDGE_AI_GATEWAY_BASE_URL=
AI_GATEWAY_EMBEDDING_PROFILE_ID=
RERANK_MODEL=
RERANK_PROFILE_ID=
