# Mainland China Docker build overlay.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   cat deploy/.env.china.example >> deploy/.env
#   DOCKER_BUILDKIT=1 docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build
#
# This file is intentionally an overlay, not a full replacement for .env.example.
# Keep tags pinned and keep Go checksum verification enabled.

# Use DaoCloud as an explicit registry rewrite. Do not rely on it as a Docker
# daemon registry-mirror; mirror mode has been observed to fail with
# ?ns=docker.io manifest requests.
DOCKER_IMAGE_REGISTRY_PREFIX=docker.m.daocloud.io/library/
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
QDRANT_IMAGE=docker.m.daocloud.io/qdrant/qdrant:v1.18.2
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=docker.m.daocloud.io/minio/mc:RELEASE.2025-08-13T08-35-41Z

# Go modules: keep checksum verification on. goproxy.cn can be fast for module
# downloads, while sum.golang.google.cn avoids the broken third-party sumdb
# proxy path that previously failed goose verification.
GO_DOCKER_GOPROXY=https://goproxy.cn,direct
GO_DOCKER_GOSUMDB=sum.golang.google.cn

# Package manager mirrors used inside Dockerfile build stages.
ALPINE_MIRROR=https://mirrors.aliyun.com/alpine
DEBIAN_APT_MIRROR=https://mirrors.aliyun.com/debian
DEBIAN_SECURITY_APT_MIRROR=https://mirrors.aliyun.com/debian-security
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
UV_DEFAULT_INDEX=https://mirrors.aliyun.com/pypi/simple
