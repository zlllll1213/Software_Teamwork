# Local development defaults. Copy this file to .env before running docker compose.

COMPOSE_PROJECT_NAME=software_teamwork_knowledge

# Knowledge Service
KNOWLEDGE_API_PORT=8000
KNOWLEDGE_SERVICE_VERSION=0.2.0
KNOWLEDGE_ENV=local
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Embedding
# local_hashing works offline for pipeline verification.
# Use openai_compatible or siliconflow when a real embedding API key is available.
EMBEDDING_PROVIDER=local_hashing
EMBEDDING_DIMENSION=384
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=knowledge
POSTGRES_DB=knowledge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=knowledge_chunks

# MinIO
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=knowledge-documents

# Admin tools
ADMINER_PORT=8080
REDIS_COMMANDER_PORT=8081
