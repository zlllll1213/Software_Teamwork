# Document service local/default settings.
# Copy to .env for local host runs, or let docker compose read this example file.

DOCUMENT_HTTP_ADDR=:8085
DOCUMENT_HTTP_PORT=8085

DOCUMENT_POSTGRES_PORT=5435
DOCUMENT_DATABASE_URL=postgres://document_app:document_app_dev@localhost:5435/document_system?sslmode=disable

DOCUMENT_REDIS_PORT=6380
DOCUMENT_REDIS_ADDR=localhost:6380

DOCUMENT_FILE_SERVICE_URL=http://localhost:8082
DOCUMENT_FILE_SERVICE_TOKEN=
DOCUMENT_AI_GATEWAY_URL=http://localhost:8086
DOCUMENT_AI_GATEWAY_PROFILE_ID=default-chat
DOCUMENT_AI_GATEWAY_SERVICE_TOKEN=
INTERNAL_SERVICE_TOKEN=

# Docker Compose uses service DNS by default. Uncomment only when overriding
# downstream URLs from inside the Compose network.
# DOCUMENT_COMPOSE_FILE_SERVICE_URL=http://file:8082
# DOCUMENT_COMPOSE_AI_GATEWAY_URL=http://ai-gateway:8086

DOCUMENT_PANDOC_PATH=pandoc
DOCUMENT_LIBREOFFICE_PATH=soffice
DOCUMENT_SHUTDOWN_TIMEOUT=10s
