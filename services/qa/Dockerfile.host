ARG IMAGE_REGISTRY_PREFIX=
ARG POSTGRES_VERSION=16-alpine

FROM ${IMAGE_REGISTRY_PREFIX}postgres:${POSTGRES_VERSION}

USER root
RUN mkdir -p /workspace && chown postgres:postgres /workspace
COPY bin/qa-server /usr/local/bin/qa-server

USER postgres
WORKDIR /workspace
EXPOSE 8084
ENTRYPOINT ["qa-server"]
